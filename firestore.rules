// ATENÇÃO: REGRA DE EDIÇÃO - Este arquivo NÃO deve ser editado sem antes discutir a alteração.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPERS DE AUTENTICAÇÃO E PAPÉIS ---

    function isAuthenticated() {
      return request.auth != null;
    }

    function isMasterAdmin() {
      return request.auth != null && 
             request.auth.token.email == 'campobrancojw@gmail.com';
    }

    // Busca o papel do usuário (padrão: PUBLICADOR) de forma robusta
    function getAuthRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
             ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'PUBLICADOR')
             : 'PUBLICADOR';
    }

    function isAdmin() {
      return isAuthenticated() && (getAuthRole() == 'ADMIN' || isMasterAdmin());
    }

    function isElder() {
      return isAuthenticated() && (getAuthRole() == 'ANCIAO' || isAdmin());
    }
    
    function isServant() {
      return isAuthenticated() && (getAuthRole() == 'SERVO' || isElder());
    }

    // --- HELPERS DE CONGREGAÇÃO (ROBUSTOS) ---
    
    // Obtém o ID da congregação de um mapa de dados (suporta camelCase e snake_case)
    function getCongId(data) {
      return data.get('congregationId', data.get('congregation_id', null));
    }

    // Verifica se o documento pertence à congregação do usuário logado
    function isSameCongregation(data) {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             getCongId(get(/databases/$(database)/documents/users/$(request.auth.uid)).data) != null &&
             getCongId(get(/databases/$(database)/documents/users/$(request.auth.uid)).data) == getCongId(data);
    }

    // --- REGRAS POR COLEÇÃO ---

    // 1. Congregações
    match /congregations/{congregationId} {
      allow read: if true; // Permitir leitura pública para exibir nome da congregação em listas compartilhadas
      allow create, delete: if isAdmin();
      allow update: if isAuthenticated() && (isAdmin() || (isServant() && (congregationId == getCongId(get(/databases/$(database)/documents/users/$(request.auth.uid)).data))));
    }

    // 2. Coleção de Usuários
    match /users/{userId} {
      // Prioriza check de UID próprio para evitar recursão no getAuthRole()
      // Publicadores podem ler outros usuários SE forem da mesma congregação
      allow read: if isAuthenticated() && (
        request.auth.uid == userId || 
        isAdmin() || 
        isServant() || 
        isSameCongregation(resource.data)
      );
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin() || isServant());
      allow delete: if isAdmin();
    }

    // 3. Cidades
    match /cities/{id} {
      allow read: if isAuthenticated() && (isAdmin() || isServant() || getAuthRole() == 'PUBLICADOR' || getAuthRole() == 'PUBLICADOR_SEM_ACESSO');
      allow create, update, delete: if isAdmin() || isServant();
    }

    // 4. Territórios e Endereços
    match /territories/{id} {
      allow read, list: if isAuthenticated() && (isAdmin() || isServant() || getAuthRole() == 'PUBLICADOR' || getAuthRole() == 'PUBLICADOR_SEM_ACESSO');
      allow create, update, delete: if isAdmin() || isServant();
    }

    match /addresses/{id} {
      allow read: if isAuthenticated();
      allow create, delete: if isAdmin() || isServant();
      allow update: if isAuthenticated() && (
        isAdmin() || isServant() || 
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['visit_status', 'last_visited_at', 'last_visited_by', 'notes', 'tags_snapshot', 'visitStatus', 'visitNotes'])
      );
      
      // Subcoleção de Histórico de Endereço
      match /history/{histId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
      }
    }

    // 5. Visitas (Histórico Individual)
    match /visits/{id} {
      allow read: if true; // Permitir leitura pública para histórico em listas compartilhadas
      allow create: if isAuthenticated(); // Escrita apenas para usuários autenticados
      allow update, delete: if isAuthenticated();
    }

    // 6. Listas Compartilhadas (Cartões)
    match /shared_lists/{id} {
      allow read: if true; // Permitir leitura pública via link direto (GUID)
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        isAdmin() || 
        isServant() || 
        resource.data.get('createdBy', null) == request.auth.uid ||
        // Permite que qualquer usuário autenticado aceite se estiver vago ou se for o designado
        (isAuthenticated() && (
          resource.data.get('assigned_to', null) == null || 
          resource.data.get('assigned_to', "") == "" || 
          resource.data.get('assignedTo', null) == null || 
          resource.data.get('assigned_to', null) == request.auth.uid ||
          resource.data.get('assignedTo', null) == request.auth.uid
        ))
      );
      allow delete: if isAdmin() || isServant() || resource.data.get('createdBy', null) == request.auth.uid;

      // Subcoleções de Listas
      match /items/{itemId} {
        allow read: if true;
        allow write: if isAuthenticated();
      }
      match /territory_addresses/{addrId} {
        allow read: if true;
        allow write: if isAuthenticated();
      }
      match /results/{resultId} {
        allow read: if true;
        allow write: if isAuthenticated();
      }
    }

    // 7. Snapshots de Listas (Públicos)
    match /shared_list_snapshots/{snapId} {
      allow read: if true;
      allow create, update: if isAuthenticated() && (isAdmin() || isServant() || getAuthRole() == 'PUBLICADOR');
      allow delete: if isAdmin() || isServant();
      
      match /visits/{id} {
        allow read: if true;
        allow create, update: if isAuthenticated() && (isAdmin() || isServant() || getAuthRole() == 'PUBLICADOR');
        allow delete: if isAdmin() || isServant();
      }
    }

    // 8. Pontos de Testemunho
    match /witnessing_points/{id} {
      allow read: if isAuthenticated() && (isAdmin() || isServant() || getAuthRole() == 'PUBLICADOR');
      allow create, delete: if isAdmin() || isServant();
      allow update: if isAuthenticated() && (
        isAdmin() || 
        isServant() || 
        getAuthRole() == 'PUBLICADOR'
      );
    }

    // 9. Miscelânea (Logs, Reports, etc)
    match /notification_templates/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /bug_reports/{reportId} {
      allow create: if isAuthenticated();
      allow read, update: if isAdmin();
    }

    match /error_reports/{reportId} {
      allow create: if isAuthenticated();
      allow read, update: if isAdmin();
    }

    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Fallback: Bloqueia tudo que não foi explicitamente permitido
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
