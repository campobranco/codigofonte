# Configurações do App
NEXT_PUBLIC_APP_NAME="Campo Branco"
NEXT_PUBLIC_APP_DESCRIPTION="Gestão de Territórios para Testemunhas de Jeová"
NEXT_PUBLIC_APP_URL="https://seu-projeto.web.app"
NEXT_PUBLIC_LEGACY_HOST=""
NEXT_PUBLIC_MASTER_EMAIL="seu-email-admin@gmail.com"

# APIs Externas
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="sua-chave-google-maps"
NEXT_PUBLIC_API_BASE_URL="https://seu-projeto.web.app/api"

# Firebase Client SDK (público)
NEXT_PUBLIC_FIREBASE_PROJECT_ID="seu-projeto-id"
NEXT_PUBLIC_FIREBASE_API_KEY="sua-api-key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="seu-projeto-id.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="seu-projeto-id.firebasestorage.app"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="seu-sender-id"
NEXT_PUBLIC_FIREBASE_APP_ID="seu-app-id"
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID="seu-measurement-id"
NEXT_PUBLIC_FIREBASE_DATABASE_ID="default"

# Firebase Admin SDK (segredo do servidor)
FIREBASE_PROJECT_ID="seu-projeto-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@seu-projeto-id.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSUA_CHAVE_AQUI\n-----END PRIVATE KEY-----\n"
