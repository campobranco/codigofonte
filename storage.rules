rules_version = '2';

// Craft rules based on data in your Firestore database
// allow write: if firestore.get(
//    /databases/default/documents/users/$(request.auth.uid)).data.isAdmin;
service firebase.storage {
  match /b/{bucket}/o {
    // Helper para buscar o papel do usuário no Firestore (banco default)
    function isAdmin() {
      return request.auth != null && 
             firestore.get(/databases/default/documents/users/$(request.auth.uid)).data.role == 'ADMIN';
    }

    // Perfis de usuário: cada usuário pode ler e escrever apenas no seu próprio diretório
    match /profiles/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Arquivos públicos (ex: ícones do app, logos das congregações)
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Negação padrão para o restante
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}